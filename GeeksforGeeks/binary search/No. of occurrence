class Solution:

# code here
    def lowerbound(self,arr,target):
        n=len(arr)
        lb=n
        low=0
        high=n-1
        while low<=high:
            mid=(low+high)//2
            if arr[mid]>=target:
                lb=mid
                high=mid-1
            else:
                low=mid+1
        return lb

    def upperbound(self,arr,target):
        n=len(arr)
        ub=n
        low=0
        high=n-1
        while low<=high:
            mid=(low+high)//2
            if arr[mid]>target:
                ub=mid
                high=mid-1
            else:
                low=mid+1
        return ub

    def countFreq(self, arr, target):
        lb=self.lowerbound(arr,target)
        ub=self.upperbound(arr,target)
        return ub-lb
